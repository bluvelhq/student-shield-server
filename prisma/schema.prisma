// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Subscriber {
  id                 String             @id @default(uuid())
  email              String             @unique
  role               Role
  firstName          String             @map("first_name")
  lastName           String             @map("last_name")
  studentId          String?            @unique @map("student_id")
  level              Int?               @map("level")
  gender             Gender
  profilePicture     String?            @map("profile_picture")
  phone              String
  serviceId          String             @unique @map("service_id")
  residence          String
  deviceCount        Int                @default(0) @map("device_count")
  accountStatus      AccountStatus      @default(ACTIVE)
  subscriptionStatus SubscriptionStatus @map("subscription_status")
  institution        Institution        @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  joinedAt           DateTime           @default(now()) @map("joined_at")
  lastLoginAt        DateTime?          @map("last_login_at")
  lastActiveAt       DateTime?          @map("last_active_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  institutionId      String             @map("institution_id")
  plan               Plan?              @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId             String?            @map("plan_id")
  payments           Payment[]
  devices            Device[]
  serviceRequests    ServiceRequest[]
  notifications      Notification[]

  @@index([email, phone, studentId])
  @@map("subscribers")
}

model Plan {
  id          String       @id @default(cuid())
  type        PlanType     @unique
  fee         Float
  maxDevices  Int          @map("max_devices")
  summary     String
  benefits    String[]
  subscribers Subscriber[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  payments    Payment[]

  @@index([id, type])
  @@map("plans")
}

model Institution {
  id          String            @id @default(cuid())
  name        String
  shortName   String            @map("short_name")
  location    String
  subscribers Subscriber[]
  status      InstitutionStatus
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([id, name, location, status])
  @@map("institutions")
}

model Payment {
  id           String        @id @default(cuid())
  subscriber   Subscriber    @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  subscriberId String        @map("subscriber_id")
  amount       Float
  method       PaymentMethod
  plan         Plan?         @relation(fields: [planId], references: [id], onDelete: Cascade)
  reference    String        @unique
  status       PaymentStatus
  type         PaymentType   @default(NEW)
  planId       String?       @map("plan_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([id, subscriberId, reference])
  @@map("payments")
}

model Device {
  id                     String                  @id @default(uuid())
  subscriber             Subscriber              @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  subscriberId           String                  @map("subscriber_id")
  type                   DeviceType
  model                  String?
  qrCode                 String?
  serialCode             String?
  name                   String?
  brand                  String?
  os                     String?
  media                  String[]
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  customDeviceAttributes CustomDeviceAttribute[]
  serviceRequests        ServiceRequest[]

  @@index([id, subscriberId])
  @@map("devices")
}

model CustomDeviceAttribute {
  id       String @id @default(uuid())
  key      String
  value    String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId String @map("device_id")

  @@index([id])
  @@map("custom_device_attributes")
}

model Admin {
  id             String         @id @default(uuid())
  privilege      Role
  email          String         @unique
  serviceId      String         @unique @map("service_id")
  firstName      String         @map("first_name")
  lastName       String         @map("last_name")
  profilePicture String?        @map("profile_picture")
  lastLoginAt    DateTime?      @map("last_login_at")
  lastActiveAt   DateTime?      @map("last_active_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  notifications  Notification[]

  @@index([id, serviceId])
  @@map("admins")
}

model ServiceRequest {
  id                        String               @id @default(uuid())
  subscriber                Subscriber           @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  subscriberId              String               @map("subscriber_id")
  device                    Device?              @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId                  String?              @map("device_id")
  type                      String
  title                     String
  description               String
  urgency                   UrgencySla
  status                    ServiceRequestStatus
  businessName              String?              @map("business_name")
  desiredSubdomain          String?              @map("desired_subdomain")
  websiteConceptDescription String?              @map("website_concept_description")
  websitePageCount          Int?                 @map("website_page_count")
  preferHosting             Boolean              @default(true) @map("prefer_hosting")
  receipt                   String?              @map("receipt")
  remarks                   String?
  qrCode                    String?              @map("qr_code")
  createdAt                 DateTime             @default(now()) @map("created_at")
  updatedAt                 DateTime             @updatedAt @map("updated_at")

  @@index([id, subscriberId, type, status])
  @@map("service_requests")
}

model Notification {
  id           String      @id @default(uuid())
  title        String
  from         String?
  body         String?
  admin        Admin?      @relation(fields: [adminId], references: [id], onDelete: Cascade)
  subscriber   Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  isRead       Boolean     @default(false)
  isSeen       Boolean     @default(false)
  isDeleted    Boolean     @default(false)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  subscriberId String?     @map("subscriber_id")
  adminId      String?     @map("admin_id")

  @@index([id, isDeleted, isRead, isSeen])
  @@map("notifications")
}

enum UrgencySla {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ServiceRequestStatus {
  OPEN
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
  DELIVERED
}

enum PaymentType {
  RENEWAL
  UPGRADE
  DOWNGRADE
  NEW
}

enum PaymentMethod {
  MOBILE_MONEY  @map("mobile_money")
  CARD          @map("card")
  CASH          @map("cash")
  BANK_TRANSFER @map("bank_transfer")
  MPESA         @map("mpesa")
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum PaymentStatus {
  PENDING
  SUCCESSFUL
  FAILED
}

enum DeviceType {
  LAPTOP
  MOBILE_PHONE
  DESKTOP
  TABLET
  OTHER
}

enum Gender {
  MALE
  FEMALE
}

enum InstitutionStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum PlanType {
  BASIC
  PREMIUM
  BONANZA
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  PENDING
  SUSPENDED
}

enum Role {
  SUBSCRIBER
  ADMIN
  SUPER_ADMIN
}
